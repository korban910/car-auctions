# Connection Strings
AUCTION_DATABASE="Server=localhost:5432;User Id=postgres;Password=postgrespw;Database=auctions"
SEARCH_DATABASE="mongodb://root:mongopw@localhost"
BIDDING_DATABASE="mongodb://root:mongopw@localhost"
IDENTITY_DATABASE="Server=localhost:5432;User Id=postgres;Password=postgrespw;Database=identities"

# DatabaseNames
SEARCH_DATABASE_NAME="SearchDb"
BIDDING_DATABASE_NAME="BidDb"

# MassTransit Prefix
AUCTION_MASS_PREFIX="auction"
SEARCH_MASS_PREFIX="search"
BID_MASS_PREFIX="bids"
NOTIFICATION_MASS_PREFIX="nt"

# Service Address
AUCTION_URL="http://localhost:7001"
SEARCH_URL="http://localhost:7002"
BIDDING_URL="http://localhost:7003"
NOTIFICATION_URL="http://localhost:7004"
IDENTITY_URL="http://localhost:5000"

# Scope
OPEN_ID_SCOPE="openid"
PROFILE_SCOPE="profile"
APP_SCOPE="auctionApp"

# Postman
POSTMAN_CLIENT_ID="postman"
POSTMAN_CLIENT_NAME="postman"
DISPLAY_NAME="Auction app full access"
POSTMAN_REDIRECTURI="https://localhost:5001/signin-oidc"
POSTMAN_SECRET="NotASecret"

# NextJS
NEXT_APP_ID="nextApp"
NEXT_CLIENT_NAME="nextApp"
NEXT_SECRET="secretApp"
NEXT_REDIRECTURI="http://localhost:3000/api/auth/callback/id-server"

# Token
CLAIM_USER_NAME="username"

# Clusters
AUCTION_CLUSTER_ID="auctions"
AUCTION_CLUSTER_READ="auctionRead"
AUCTION_CLUSTER_WRITE="auctionWrite"
SEARCH_CLUSTER_ID="search"
SEARCH_CLUSTER_READ="search"
BIDS_CLUSTER_READ="bidsRead"
BIDS_CLUSTER_WRITE="bidsWrite"
BIDS_CLUSTER_ID="bids"
AUTHORIZATION_POLICY="Default"
NOTIFICATION_CLUSTER="notifications"
NOTIFICATION_CLUSTER_ID="notifications"
AUCTION_API="auctionApi"
SEARCH_API="searchApi"
BIDS_API="bidApi"
NOTIFICATION_API="notifyApi"

# RabbitMq
RABBITMQ_HOST="localhost"
RABBITMQ_USER="guest"
RABBITMQ_PASSWORD="guest"
RABBITMQ_HOST_NAME="rabbitmq"

# MongoDb
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=mongopw

# Docker Connection Strings
DOCKER_AUCTION_DATABASE="Server=postgres:5432;User Id=postgres;Password=postgrespw;Database=auctions"
DOCKER_SEARCH_DATABASE="mongodb://root:mongopw@mongodb"
DOCKER_BID_DATABASE="mongodb://root:mongopw@mongodb"
DOCKER_IDENTITY_DATABASE="Server=postgres:5432;User Id=postgres;Password=postgrespw;Database=identities"
DOCKER_CLAIM_USER_NAME="username"

# ASPNETCORE
ASPNETCORE_ENVIRONMENT="Development"
ASPNETCORE_DOCKER_ENVIRONMENT="Docker"

# Docker Service Address
DOCKER_AUCTION_URL="http://auction-svc"
DOCKER_SEARCH_URL="http://search-svc"
DOCKER_IDENTITY_URL="http://identity-svc"
DOCKER_BIDDING_URL="http://bid-svc"
DOCKER_NOTIFICATION_URL="http://notify-svc"
DOCKER_ASPNETCORE_URLS="http://+:80"
DOCKER_GRPC_URL="http://auction-svc:7777"
DOCKER_GRPC_PORT="7777"
DOCKER_WEB_API_PORT="80"

# Grpc
GRPC_URL="http://localhost:7777"
